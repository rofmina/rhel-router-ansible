[connection]
id=Intranet
uuid=cb952195-0627-4c0a-95b3-2071b5b1eb9c
type=ethernet
autoconnect=true
interface-name={{ intranet_interface }}

[ethernet]
mac-address={{ intranet_mac }}

[ipv4]
address1={{ intranet_static_ip }}/{{ intranet_cidr }}
method=manual
never-default=true

[ipv6]
addr-gen-mode=eui64
method=ignore

[proxy]
